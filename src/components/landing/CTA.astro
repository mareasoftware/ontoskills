---
import Button from '../ui/Button.astro';
---

<section class="py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
      Stop reading. <span class="gradient-text">Start querying.</span>
    </h2>
    <p class="text-text-muted mb-8 max-w-2xl mx-auto">
      Give your AI agents ontoskills — structured, evolving knowledge
      they can query instead of guess.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/overview/" size="lg">
        Explore Ontoskills
      </Button>
      <Button href="https://github.com/mareasoftware/ontoclaw" variant="secondary" size="lg">
        View on GitHub
      </Button>
    </div>
  </div>
</section>
