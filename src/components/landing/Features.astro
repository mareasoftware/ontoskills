---
import Card from '../ui/Card.astro';

const features = [
  {
    title: 'Ontoskill Query',
    description: 'SPARQL O(1) indexed lookup instead of O(n) text scanning across skill files.',
    icon: '🔍'
  },
  {
    title: 'Deterministic Reasoning',
    description: 'The graph responds with precise answers. No interpretation, no hallucination.',
    icon: '🎯'
  },
  {
    title: 'Evolving Knowledge',
    description: 'ABox updates automatically when the LLM succeeds or fails. Learning from execution.',
    icon: '🔄'
  },
  {
    title: 'Stable Foundations',
    description: 'TBox and RBox define consistent rules. Prerequisites, constraints, capabilities.',
    icon: '🏛️'
  },
  {
    title: 'MCP Protocol Native',
    description: 'Direct integration with Claude Desktop, VSCode, and any MCP-compatible client.',
    icon: '🔌'
  },
  {
    title: 'Secure Pipeline',
    description: 'Unicode normalization + pattern validation + LLM review for threat detection.',
    icon: '🔒'
  }
];
---

<section id="features" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        How <span class="gradient-text">Ontoskills</span> Work
      </h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        Not files to read. A graph to query.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <Card
          title={feature.title}
          description={feature.description}
          icon={feature.icon}
        />
      ))}
    </div>
  </div>
</section>
