---
import { OFFICIAL_REGISTRY_INDEX_URL, OFFICIAL_REGISTRY_REPO_URL } from '../../data/registry';

interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
  showHeader?: boolean;
}

const {
  title = 'Live Registry Marketplace',
  description = 'Search the official registry, copy install commands, and pull exactly the skill you want.',
  compact = false,
  showHeader = true,
} = Astro.props;

const rootId = `market-${crypto.randomUUID()}`;
---

<section id="marketplace" class={`${compact ? 'py-16' : 'py-20'}`}>
  <div class="section-shell">
    {showHeader && (
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <div class="section-kicker mx-auto mb-4">Registry marketplace</div>
        <h2 class="mb-4 text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl">
          {title}
        </h2>
        <p class="text-base leading-7 text-text-secondary sm:text-lg">{description}</p>
      </div>
    )}

    <div id={rootId} class="glass-panel rounded-[2rem] p-5 sm:p-7">
      <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <div class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-text-muted">
            Official registry
          </div>
          <p class="text-sm leading-6 text-text-secondary sm:text-base">
            Browse verified skills published in the official registry. Each card exposes the exact command
            to install and enable the skill locally.
          </p>
        </div>
        <a
          href="/explore/"
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-text-primary transition hover:border-accent-cyan/30 hover:bg-white/10"
        >
          Open full marketplace
        </a>
      </div>

      <div class="mb-5 grid gap-4 lg:grid-cols-[1fr_auto]">
        <label class="glass-panel flex items-center gap-3 rounded-2xl px-4 py-3">
          <span class="text-text-muted">⌕</span>
          <input
            class="w-full bg-transparent text-sm text-text-primary outline-none placeholder:text-text-muted"
            type="search"
            placeholder="Search skills, aliases, packages, or descriptions"
            data-role="search"
          />
        </label>
        <div class="glass-panel flex items-center rounded-2xl px-4 py-3 text-sm text-text-secondary">
          <span data-role="count">Loading registry...</span>
        </div>
      </div>

      <div data-role="status" class="mb-5 rounded-2xl border border-dashed border-white/12 bg-white/4 px-4 py-4 text-sm text-text-secondary">
        Connecting to the official registry…
      </div>

      <div data-role="grid" class="marketplace-grid"></div>
    </div>
  </div>
</section>

<script define:vars={{ rootId, registryIndexUrl: OFFICIAL_REGISTRY_INDEX_URL, registryRepoUrl: OFFICIAL_REGISTRY_REPO_URL }} is:inline>
  const root = document.getElementById(rootId);
  const search = root?.querySelector('[data-role="search"]');
  const grid = root?.querySelector('[data-role="grid"]');
  const status = root?.querySelector('[data-role="status"]');
  const count = root?.querySelector('[data-role="count"]');

  const escapeHtml = (value) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const normalizeSkill = (pkg, skill) => {
    const qualifiedId = `${pkg.package_id}/${skill.id}`;
    return {
      packageId: pkg.package_id,
      skillId: skill.id,
      qualifiedId,
      description: skill.description || pkg.description || 'No description available yet.',
      aliases: Array.isArray(skill.aliases) ? skill.aliases : [],
      trustTier: pkg.trust_tier || 'verified',
      dependsOn: Array.isArray(skill.depends_on_skills) ? skill.depends_on_skills : [],
      source: pkg.source || registryRepoUrl,
      installCommand: `npx ontoskills install ${qualifiedId}`,
      enableCommand: `npx ontoskills enable ${qualifiedId}`,
    };
  };

  const renderCard = (skill) => {
    const aliases = skill.aliases.length
      ? skill.aliases.map((alias) => `<span class="rounded-full border border-white/10 bg-white/6 px-2 py-1 text-xs text-text-secondary">${escapeHtml(alias)}</span>`).join('')
      : '<span class="text-xs text-text-muted">No aliases</span>';

    const depends = skill.dependsOn.length
      ? `<div class="mt-3 text-xs text-text-muted">Depends on: ${escapeHtml(skill.dependsOn.join(', '))}</div>`
      : '';

    return `
      <article class="glass-panel rounded-[1.5rem] p-5 transition hover:-translate-y-1 hover:border-[rgba(126,217,255,0.32)] hover:bg-[rgba(255,255,255,0.08)]">
        <div class="mb-4 flex items-start justify-between gap-3">
          <div>
            <div class="mb-1 text-sm font-semibold uppercase tracking-[0.16em] text-text-muted">${escapeHtml(skill.packageId)}</div>
            <h3 class="text-xl font-semibold text-text-primary">${escapeHtml(skill.skillId)}</h3>
          </div>
          <span class="glass-badge">${escapeHtml(skill.trustTier)}</span>
        </div>
        <p class="mb-4 min-h-[4.5rem] text-sm leading-6 text-text-secondary">${escapeHtml(skill.description)}</p>
        <div class="mb-4 flex flex-wrap gap-2">${aliases}</div>
        ${depends}
        <div class="mt-5 rounded-2xl border border-white/10 bg-[#08111f]/70 p-3">
          <div class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-text-muted">Install</div>
          <code class="block break-all text-sm text-text-primary">${escapeHtml(skill.installCommand)}</code>
        </div>
        <div class="mt-4 flex flex-wrap gap-3">
          <button type="button" data-copy="${escapeHtml(skill.installCommand)}" class="inline-flex items-center justify-center rounded-full bg-accent-cyan px-4 py-2 text-sm font-medium text-[#04111d] transition hover:bg-[#93e4ff]">
            Copy install
          </button>
          <button type="button" data-copy="${escapeHtml(skill.enableCommand)}" class="inline-flex items-center justify-center rounded-full border border-white/12 bg-white/6 px-4 py-2 text-sm font-medium text-text-primary transition hover:border-accent-cyan/30 hover:bg-white/10">
            Copy enable
          </button>
        </div>
      </article>
    `;
  };

  let skills = [];

  const render = () => {
    if (!grid || !count || !status) return;
    const query = (search?.value || '').trim().toLowerCase();
    const filtered = skills.filter((skill) => {
      const haystack = [
        skill.packageId,
        skill.skillId,
        skill.qualifiedId,
        skill.description,
        skill.aliases.join(' '),
      ]
        .join(' ')
        .toLowerCase();
      return haystack.includes(query);
    });

    count.textContent = `${filtered.length} skill${filtered.length === 1 ? '' : 's'} available`;

    if (!skills.length) {
      status.innerHTML = `Unable to load skills right now. <a href="${registryRepoUrl}" target="_blank" rel="noopener" class="text-accent-cyan underline">Open the official registry</a>.`;
      grid.innerHTML = '';
      return;
    }

    status.textContent = query
      ? `Showing results for “${search.value.trim()}”`
      : 'Verified skills from the official registry. Copy the command and try one right away.';

    if (!filtered.length) {
      grid.innerHTML = `
        <div class="glass-panel col-span-full rounded-[1.5rem] p-8 text-center">
          <p class="text-lg font-medium text-text-primary">No matching skills.</p>
          <p class="mt-2 text-sm text-text-secondary">Try “hello”, “xlsx”, “docx”, or “office”.</p>
        </div>
      `;
      return;
    }

    grid.innerHTML = filtered.map(renderCard).join('');
  };

  const loadRegistry = async () => {
    if (!status || !count) return;

    try {
      const indexResponse = await fetch(registryIndexUrl, { mode: 'cors' });
      if (!indexResponse.ok) throw new Error(`Index request failed: ${indexResponse.status}`);
      const indexData = await indexResponse.json();
      const manifests = await Promise.all(
        (indexData.packages || []).map(async (entry) => {
          const manifestUrl = new URL(entry.manifest_url, registryIndexUrl).toString();
          const response = await fetch(manifestUrl, { mode: 'cors' });
          if (!response.ok) throw new Error(`Manifest request failed: ${response.status}`);
          return response.json();
        })
      );

      skills = manifests.flatMap((pkg) => (pkg.skills || []).map((skill) => normalizeSkill(pkg, skill)));
      skills.sort((left, right) => left.qualifiedId.localeCompare(right.qualifiedId));
      render();
    } catch (error) {
      console.error(error);
      skills = [];
      render();
    }
  };

  root?.addEventListener('click', async (event) => {
    const target = event.target.closest('[data-copy]');
    if (!target) return;
    const command = target.getAttribute('data-copy') ?? '';
    const original = target.textContent;
    try {
      await navigator.clipboard.writeText(command);
      target.textContent = 'Copied';
      setTimeout(() => {
        target.textContent = original;
      }, 1500);
    } catch {
      target.textContent = 'Copy failed';
      setTimeout(() => {
        target.textContent = original;
      }, 1500);
    }
  });

  search?.addEventListener('input', render);
  loadRegistry();
</script>
